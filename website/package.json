{
  "name": "hookwing-website",
  "private": true,
  "version": "0.0.0",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "sharp": "^0.34.4"
  },
  "scripts": {
    "lint": "node --check ./scripts/build-content.mjs && node --check ./scripts/validate-content.mjs && node --check ./scripts/optimize-images.mjs",
    "validate": "node ./scripts/validate-content.mjs",
    "test": "npm run lint && npm run validate",
    "build:media": "node ./scripts/optimize-images.mjs",
    "build:content": "npm run build:media && node ./scripts/build-content.mjs",
    "build": "npm run build:content",
    "prepare:preview": "node ./scripts/prepare-preview-dist.mjs"
  },
  "overrides": {
    "axios": ">=1.14.0 <1.14.1 || >=1.14.2",
    "plain-crypto-js": "npm:@empty-npm-package/empty@1.0.0"
  }
}
