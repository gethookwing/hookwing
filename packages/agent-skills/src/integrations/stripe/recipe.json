{
  "name": "stripe",
  "displayName": "Stripe Payments",
  "description": "Handle Stripe webhook events — payments, subscriptions, invoices",
  "signatureHeader": "Stripe-Signature",
  "signatureMethod": "HMAC-SHA256 with timestamp",
  "commonEvents": [
    "payment_intent.succeeded",
    "payment_intent.payment_failed",
    "payment_intent.created",
    "customer.subscription.created",
    "customer.subscription.updated",
    "customer.subscription.deleted",
    "customer.created",
    "customer.updated",
    "invoice.paid",
    "invoice.payment_failed",
    "invoice.created",
    "charge.succeeded",
    "charge.failed",
    "charge.refunded",
    "checkout.session.completed",
    "checkout.session.expired"
  ],
  "hookwing": {
    "endpointName": "stripe-webhooks",
    "eventTypes": [
      "payment_intent.*",
      "customer.subscription.*",
      "customer.*",
      "invoice.*",
      "charge.*",
      "checkout.session.*"
    ]
  }
}
