{
  "name": "sendgrid",
  "displayName": "SendGrid",
  "description": "Handle SendGrid webhook events — email delivery, opens, clicks, bounces, unsubscribes",
  "signatureHeader": "X-Twilio-Email-Event-Webhook-Signature",
  "signatureMethod": "HMAC-SHA256 (base64)",
  "commonEvents": [
    "processed",
    "delivered",
    "bounced",
    "dropped",
    "blocked",
    "spam_report",
    "open",
    "click",
    "unsubscribe",
    "group_unsubscribe",
    "group_resubscribe"
  ],
  "hookwing": {
    "endpointName": "sendgrid-webhooks",
    "eventTypes": [
      "email_processed",
      "email_delivered",
      "email_bounced",
      "email_dropped",
      "email_blocked",
      "spam_reported",
      "email_opened",
      "link_clicked",
      "unsubscribed",
      "group_unsubscribed",
      "group_resubscribed"
    ]
  }
}
