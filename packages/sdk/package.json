{
  "name": "@hookwing/sdk",
  "version": "0.0.1",
  "description": "Hookwing JavaScript/TypeScript SDK — webhook signature verification and client utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
