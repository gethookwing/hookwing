    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["hookwing", "webhooks", "sdk", "signature-verification"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
