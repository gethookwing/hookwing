{
  "$schema": "https://www.designtokens.org/schema.json",
  "$description": "Hookwing canonical brand tokens. Source of truth for tokens.css generation.",

  "primitive": {
    "blue": {
      "950": { "$value": "#001A24", "$type": "color" },
      "900": { "$value": "#002A3A", "$type": "color" },
      "800": { "$value": "#003D54", "$type": "color" },
      "700": { "$value": "#005070", "$type": "color" },
      "100": { "$value": "#E8F4F9", "$type": "color" },
      "50":  { "$value": "#F4F9FC", "$type": "color" }
    },
    "green": {
      "700": { "$value": "#006B44", "$type": "color" },
      "600": { "$value": "#009D64", "$type": "color" },
      "500": { "$value": "#00C07A", "$type": "color" },
      "100": { "$value": "#D6F5E9", "$type": "color" },
      "50":  { "$value": "#EDFAF4", "$type": "color" }
    },
    "yellow": {
      "600": { "$value": "#E6A800", "$type": "color" },
      "500": { "$value": "#FFC107", "$type": "color" },
      "400": { "$value": "#FFCD38", "$type": "color" },
      "100": { "$value": "#FFF3CC", "$type": "color" },
      "50":  { "$value": "#FFFAE8", "$type": "color" }
    },
    "neutral": {
      "950": { "$value": "#0B1220", "$type": "color" },
      "800": { "$value": "#1E293B", "$type": "color" },
      "700": { "$value": "#475569", "$type": "color" },
      "400": { "$value": "#94A3B8", "$type": "color" },
      "200": { "$value": "#DCE3EA", "$type": "color" },
      "100": { "$value": "#F1F5F9", "$type": "color" },
      "50":  { "$value": "#FDFBF4", "$type": "color" },
      "white": { "$value": "#FFFFFF", "$type": "color" }
    },
    "red": {
      "600": { "$value": "#DC2626", "$type": "color" },
      "100": { "$value": "#FEE2E2", "$type": "color" }
    }
  },

  "semantic": {
    "color": {
      "bg":              { "$value": "{primitive.neutral.50}",  "$type": "color" },
      "surface":         { "$value": "{primitive.neutral.white}", "$type": "color" },
      "surface-raised":  { "$value": "{primitive.neutral.100}", "$type": "color" },
      "ink-strong":      { "$value": "{primitive.neutral.950}", "$type": "color" },
      "ink-base":        { "$value": "{primitive.neutral.800}", "$type": "color" },
      "ink-muted":       { "$value": "{primitive.neutral.700}", "$type": "color" },
      "ink-disabled":    { "$value": "{primitive.neutral.400}", "$type": "color" },
      "ink-inverse":     { "$value": "{primitive.neutral.white}", "$type": "color" },
      "brand-primary":   { "$value": "{primitive.blue.900}",   "$type": "color" },
      "brand-secondary": { "$value": "{primitive.blue.800}",   "$type": "color" },
      "brand-action":    { "$value": "{primitive.green.600}",  "$type": "color" },
      "brand-action-hover": { "$value": "{primitive.green.700}", "$type": "color" },
      "brand-signal":    { "$value": "{primitive.yellow.500}", "$type": "color" },
      "border":          { "$value": "{primitive.neutral.200}", "$type": "color" },
      "border-strong":   { "$value": "{primitive.neutral.400}", "$type": "color" },
      "border-brand":    { "$value": "{primitive.green.600}",  "$type": "color" },
      "success":         { "$value": "{primitive.green.600}",  "$type": "color" },
      "success-bg":      { "$value": "{primitive.green.50}",   "$type": "color" },
      "warning":         { "$value": "{primitive.yellow.500}", "$type": "color" },
      "warning-bg":      { "$value": "{primitive.yellow.50}",  "$type": "color" },
      "error":           { "$value": "{primitive.red.600}",    "$type": "color" },
      "error-bg":        { "$value": "{primitive.red.100}",    "$type": "color" }
    }
  },

  "dark": {
    "color": {
      "bg":              { "$value": "{primitive.blue.950}", "$type": "color" },
      "surface":         { "$value": "{primitive.blue.900}", "$type": "color" },
      "surface-raised":  { "$value": "{primitive.blue.800}", "$type": "color" },
      "ink-strong":      { "$value": "{primitive.neutral.white}", "$type": "color" },
      "ink-base":        { "$value": "#CBD5E1", "$type": "color" },
      "ink-muted":       { "$value": "{primitive.neutral.400}", "$type": "color" },
      "ink-disabled":    { "$value": "#475569", "$type": "color" },
      "ink-inverse":     { "$value": "{primitive.neutral.950}", "$type": "color" },
      "brand-primary":   { "$value": "{primitive.green.500}", "$type": "color" },
      "brand-secondary": { "$value": "{primitive.green.600}", "$type": "color" },
      "brand-action":    { "$value": "{primitive.green.500}", "$type": "color" },
      "brand-action-hover": { "$value": "{primitive.green.600}", "$type": "color" },
      "brand-signal":    { "$value": "{primitive.yellow.400}", "$type": "color" },
      "success":         { "$value": "{primitive.green.500}", "$type": "color" },
      "error":           { "$value": "#F87171", "$type": "color" }
    }
  },

  "typography": {
    "font-display": { "$value": "'Space Grotesk', system-ui, sans-serif", "$type": "fontFamily" },
    "font-body":    { "$value": "'Inter', system-ui, sans-serif", "$type": "fontFamily" },
    "font-mono":    { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" },
    "scale": {
      "display": { "size": { "$value": "64px" }, "lineHeight": { "$value": "72px" }, "weight": { "$value": "700" } },
      "h1":      { "size": { "$value": "52px" }, "lineHeight": { "$value": "60px" }, "weight": { "$value": "700" } },
      "h2":      { "size": { "$value": "38px" }, "lineHeight": { "$value": "48px" }, "weight": { "$value": "600" } },
      "h3":      { "size": { "$value": "28px" }, "lineHeight": { "$value": "36px" }, "weight": { "$value": "600" } },
      "h4":      { "size": { "$value": "22px" }, "lineHeight": { "$value": "30px" }, "weight": { "$value": "600" } },
      "h5":      { "size": { "$value": "18px" }, "lineHeight": { "$value": "26px" }, "weight": { "$value": "600" } },
      "body":    { "size": { "$value": "16px" }, "lineHeight": { "$value": "26px" }, "weight": { "$value": "400" } },
      "small":   { "size": { "$value": "14px" }, "lineHeight": { "$value": "22px" }, "weight": { "$value": "400" } },
      "label":   { "size": { "$value": "12px" }, "lineHeight": { "$value": "16px" }, "weight": { "$value": "500" } },
      "code":    { "size": { "$value": "14px" }, "lineHeight": { "$value": "22px" }, "weight": { "$value": "400" } }
    }
  },

  "spacing": {
    "1":  { "$value": "4px",   "$type": "dimension", "$description": "hair" },
    "2":  { "$value": "8px",   "$type": "dimension", "$description": "tight" },
    "3":  { "$value": "12px",  "$type": "dimension", "$description": "snug" },
    "4":  { "$value": "16px",  "$type": "dimension", "$description": "comfortable" },
    "5":  { "$value": "24px",  "$type": "dimension", "$description": "roomy" },
    "6":  { "$value": "32px",  "$type": "dimension", "$description": "open" },
    "7":  { "$value": "40px",  "$type": "dimension" },
    "8":  { "$value": "48px",  "$type": "dimension", "$description": "spacious" },
    "9":  { "$value": "64px",  "$type": "dimension", "$description": "airy" },
    "10": { "$value": "80px",  "$type": "dimension" },
    "11": { "$value": "96px",  "$type": "dimension" },
    "12": { "$value": "128px", "$type": "dimension" }
  },

  "radius": {
    "xs":   { "$value": "4px",    "$type": "dimension" },
    "sm":   { "$value": "8px",    "$type": "dimension" },
    "md":   { "$value": "12px",   "$type": "dimension" },
    "lg":   { "$value": "16px",   "$type": "dimension" },
    "xl":   { "$value": "24px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "shadow": {
    "sm":    { "$value": "0 1px 3px rgba(2,6,23,.06)",   "$type": "shadow" },
    "md":    { "$value": "0 4px 12px rgba(2,6,23,.08)",  "$type": "shadow" },
    "lg":    { "$value": "0 8px 22px rgba(2,6,23,.10)",  "$type": "shadow" },
    "xl":    { "$value": "0 20px 44px rgba(2,6,23,.14)", "$type": "shadow" },
    "focus": { "$value": "0 0 0 3px #86B7FE",            "$type": "shadow" },
    "brand": { "$value": "0 4px 16px rgba(0,157,100,.25)", "$type": "shadow" }
  },

  "motion": {
    "duration": {
      "instant": { "$value": "60ms",  "$type": "duration" },
      "fast":    { "$value": "120ms", "$type": "duration" },
      "base":    { "$value": "200ms", "$type": "duration" },
      "slow":    { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(.2,.8,.2,1)",     "$type": "cubicBezier" },
      "decel":   { "$value": "cubic-bezier(.0,.0,.2,1)",     "$type": "cubicBezier" },
      "spring":  { "$value": "cubic-bezier(.34,1.56,.64,1)", "$type": "cubicBezier" }
    }
  },

  "layout": {
    "container-sm":  { "$value": "640px",  "$type": "dimension" },
    "container-md":  { "$value": "800px",  "$type": "dimension" },
    "container-lg":  { "$value": "1120px", "$type": "dimension" },
    "container-xl":  { "$value": "1280px", "$type": "dimension" },
    "nav-height":    { "$value": "64px",   "$type": "dimension" }
  },

  "dataViz": {
    "1": { "$value": "#009D64", "$type": "color", "$description": "Emerald (primary)" },
    "2": { "$value": "#FFC107", "$type": "color", "$description": "Amber" },
    "3": { "$value": "#38BDF8", "$type": "color", "$description": "Sky blue" },
    "4": { "$value": "#A78BFA", "$type": "color", "$description": "Violet" },
    "5": { "$value": "#FB923C", "$type": "color", "$description": "Orange" },
    "6": { "$value": "#F472B6", "$type": "color", "$description": "Pink" },
    "7": { "$value": "#34D399", "$type": "color", "$description": "Mint" }
  }
}
